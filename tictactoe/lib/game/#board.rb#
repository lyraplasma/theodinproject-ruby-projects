class Board
  attr_accessor :board
  def initialize
    @board = ('a'..'i').to_a
    
  end
  def reset_board
    @board = ('a'..'i').to_a
  end
  def draw
    puts "\t\t==================================="
    puts "\t\t\t#{@board[0]}|#{@board[1]}|#{@board[2]}"
    puts "\t\t\t#{@board[3]}|#{@board[4]}|#{@board[5]}\t\t <<<<<< Use Notation!"
    puts "\t\t\t#{@board[6]}|#{@board[7]}|#{@board[8]}"    
    puts "\t\t==================================="    
  end
end
